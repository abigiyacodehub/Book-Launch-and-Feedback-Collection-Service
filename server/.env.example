# Server runtime
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# Authorization: choose Clerk or Auth0 and leave the unused provider blank
CLERK_API_KEY=sk_test_placeholder
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.constant-ya.local
AUTH0_CLIENT_ID=auth0_client_id_placeholder
AUTH0_CLIENT_SECRET=auth0_client_secret_placeholder

# Media and future integrations
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
TELEGRAM_BOT_TOKEN=telegram_bot_token_placeholder
