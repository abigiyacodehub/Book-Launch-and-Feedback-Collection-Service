# Set these in Vercel or Netlify project environment variables.
VITE_API_BASE_URL=https://your-backend-api.example.com/api

# Clerk frontend key, if Clerk is selected
VITE_CLERK_PUBLISHABLE_KEY=pk_live_placeholder

# Auth0 frontend keys, if Auth0 is selected
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=auth0_client_id_placeholder
VITE_AUTH0_AUDIENCE=https://api.constant-ya.org
